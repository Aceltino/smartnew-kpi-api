# Database Configuration (MySQL via DigitalOcean or local)
# Format: mysql://username:password@host:port/database_name
# Example: mysql://root:password@localhost:3306/softwareman_db
# DO NOT commit .env - it contains real credentials
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"
NODE_ENV=production
PORT=3001
# Authentication Token (must be Bearer format)
# For testing: Bearer test-token-123
BEARER_TOKEN=test-token-123
# CORS Configuration
CORS_ORIGIN=http://localhost:3000
